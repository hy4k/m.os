# Runtime
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personal_llm_os

# User uploads (API stores multipart files here; use a Docker volume path in production)
# UPLOAD_DIR=./data/uploads

# Security
JWT_ISSUER=personal-llm-os
JWT_AUDIENCE=personal-llm-os-app
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
MASTER_ENCRYPTION_KEY_BASE64=
SESSION_COOKIE_NAME=pllos_session

# Azure Ollama
AZURE_OLLAMA_BASE_URL=http://azure-ollama.internal:11434
AZURE_OLLAMA_MODEL=gemma4:e4b
AZURE_OLLAMA_FALLBACK_MODELS=gemma3:12b,qwen3-coder:latest

# Hostinger small model (optional)
HOSTINGER_OLLAMA_BASE_URL=http://127.0.0.1:11434
HOSTINGER_OLLAMA_MODEL=gemma3:4b

# Cloud fallback (quality-first)
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=

# Embeddings (served from same Azure Ollama host)
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# m.OS copilot: Ollama /api/chat on Azure (Gemma 4)
# MOS_SYSTEM_PROMPT=
OLLAMA_NUM_CTX=16384
OLLAMA_ASSISTANT_TEMPERATURE=0.35

# Optional: GitHub import (user PAT or per-user `github_pat` credential preferred)
# GITHUB_TOKEN=

# API rate limit (requests / IP / minute). 0 = off (good for local dev).
# RATE_LIMIT_MAX_PER_MINUTE=200

# noteos.in / production: lock API to signed-in users and real browser origins
# CORS_ORIGIN=https://noteos.in,https://www.noteos.in
# ALLOW_X_USER_ID_HEADER=false
# For same-host deploy (Caddy → web + api): NEXT_PUBLIC_API_BASE_URL=https://noteos.in

# Workers (optional cron): call API health
# API_BASE_URL=https://noteos.in
# WORKER_MODE=once
# WORKER_INTERVAL_MINUTES=60
