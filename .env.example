# Runtime
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personal_llm_os

# Security
JWT_ISSUER=personal-llm-os
JWT_AUDIENCE=personal-llm-os-app
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
MASTER_ENCRYPTION_KEY_BASE64=
SESSION_COOKIE_NAME=pllos_session

# Azure Ollama
AZURE_OLLAMA_BASE_URL=http://azure-ollama.internal:11434
AZURE_OLLAMA_MODEL=gemma4:e4b
AZURE_OLLAMA_FALLBACK_MODELS=gemma3:12b,qwen3-coder:latest

# Hostinger small model (optional)
HOSTINGER_OLLAMA_BASE_URL=http://127.0.0.1:11434
HOSTINGER_OLLAMA_MODEL=gemma3:4b

# Cloud fallback (quality-first)
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=

# Embeddings
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional: GitHub import (user PAT or per-user `github_pat` credential preferred)
# GITHUB_TOKEN=
