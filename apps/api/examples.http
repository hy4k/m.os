### Health
GET http://localhost:4000/health

### Register
POST http://localhost:4000/api/auth/register
Content-Type: application/json

{
  "email": "owner@personal-os.local",
  "password": "change-this-password",
  "display_name": "Midhun"
}

### Login
POST http://localhost:4000/api/auth/login
Content-Type: application/json

{
  "email": "owner@personal-os.local",
  "password": "change-this-password"
}

### Create project
POST http://localhost:4000/api/projects
Content-Type: application/json
x-user-id: 00000000-0000-0000-0000-000000000001

{
  "name": "noteos platform evolution",
  "description": "Main personal command center project",
  "platform": "hostinger+azure"
}

### Add note
POST http://localhost:4000/api/notes
Content-Type: application/json
x-user-id: 00000000-0000-0000-0000-000000000001

{
  "title": "new product idea",
  "content": "Agentic vault for all projects and life goals",
  "kind": "idea"
}

### Add credential
POST http://localhost:4000/api/credentials
Content-Type: application/json
x-user-id: 00000000-0000-0000-0000-000000000001

{
  "label": "github token",
  "kind": "api_key",
  "secret": "ghp_example_secret"
}

### GitHub PAT (for import via credential)
POST http://localhost:4000/api/credentials
Content-Type: application/json
x-user-id: 00000000-0000-0000-0000-000000000001

{
  "label": "GitHub PAT",
  "kind": "github_pat",
  "secret": "ghp_your_fine_grained_or_classic_token"
}

### Import GitHub repos to project (uses token, credential_id, or server GITHUB_TOKEN)
POST http://localhost:4000/api/connectors/github/import-repos
Content-Type: application/json
x-user-id: 00000000-0000-0000-0000-000000000001

{
  "project_id": "REPLACE_WITH_PROJECT_UUID",
  "token": "ghp_...",
  "store_token": false
}

### Assistant chat (RAG: semantic note retrieval + full project context)
POST http://localhost:4000/api/assistant/chat
Content-Type: application/json
x-user-id: 00000000-0000-0000-0000-000000000001

{
  "policy": "coding",
  "prompt": "Summarize my current active projects and next 3 actions.",
  "include_rag": true,
  "rag_limit": 8
}
